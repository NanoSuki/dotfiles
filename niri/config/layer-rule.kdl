// Layer rules
// Place the regular wallpaper on the backdrop.
layer-rule {
    match namespace=r#"^noctalia-wallpaper"#
    place-within-backdrop true
}
layer-rule {
    match namespace=r#"^noctalia-(bar-[^"]+|notification|dock|panel|attached-panel|osd)$"#
    background-effect {
        xray false
        // blur false
    }
}
